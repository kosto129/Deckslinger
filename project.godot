; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited if needed.

[application]

config/name="Deckslinger"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"
run/main_scene="res://src/Main.tscn"

[autoload]

Enums="*res://src/core/enums.gd"
InputManager="*res://src/foundation/input_manager.gd"
CardRegistry="*res://src/foundation/card_registry.gd"
SceneManager="*res://src/core/scene_manager.gd"
GameManager="*res://src/core/game_manager.gd"

[display]

window/size/viewport_width=384
window/size/viewport_height=216
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

